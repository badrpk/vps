{
  "name": "vps-pk-cloud-platform",
  "version": "1.0.0",
  "description": "Complete cloud services platform with 200+ services covering all major cloud provider capabilities",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run lint && npm run test:unit",
    "deploy": "npm run build && npm start",
    
    "test": "node testing/test-runner.js",
    "test:all": "node testing/test-runner.js --enableUnitTests=true --enableIntegrationTests=true --enableAPITests=true --enablePerformanceTests=true --enableSecurityTests=true --enableLoadTests=true --enableE2ETests=true",
    "test:unit": "node testing/test-runner.js --enableUnitTests=true --enableIntegrationTests=false --enableAPITests=false --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=false",
    "test:integration": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=true --enableAPITests=false --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=false",
    "test:api": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=true --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=false",
    "test:performance": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=false --enablePerformanceTests=true --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=false",
    "test:security": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=false --enablePerformanceTests=false --enableSecurityTests=true --enableLoadTests=false --enableE2ETests=false",
    "test:load": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=false --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=true --enableE2ETests=false",
    "test:e2e": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=false --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=true",
    "test:smoke": "node testing/test-runner.js --enableUnitTests=false --enableIntegrationTests=false --enableAPITests=true --enablePerformanceTests=false --enableSecurityTests=false --enableLoadTests=false --enableE2ETests=false",
    "test:owasp": "node testing/vpspk-security-tester.js --enableOWASP=true",
    "test:report": "node testing/test-runner.js --generateReport=true",
    
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deps:check": "npm audit --audit-level=moderate",
    "deps:update": "npm update",
    
    "load:light": "node testing/vpspk-load-tester.js --scenario=light",
    "load:medium": "node testing/vpspk-load-tester.js --scenario=medium",
    "load:heavy": "node testing/vpspk-load-tester.js --scenario=heavy",
    "load:stress": "node testing/vpspk-load-tester.js --scenario=stress",
    "load:spike": "node testing/vpspk-load-tester.js --scenario=spike",
    
    "security:scan": "node testing/vpspk-security-tester.js",
    "security:owasp": "node testing/vpspk-security-tester.js --enableOWASP=true",
    "security:penetration": "node testing/vpspk-security-tester.js --enablePenetrationTesting=true",
    
    "monitor": "node monitoring/vpspk-monitor.js",
    "optimize": "node optimization/vpspk-performance-optimizer.js",
    "backup": "bash backup-recovery/backup-system.sh full",
    "backup:incremental": "bash backup-recovery/backup-system.sh incremental",
    "backup:database": "bash backup-recovery/backup-system.sh database",
    "restore": "bash backup-recovery/backup-system.sh restore",
    
    "docs": "jsdoc -c jsdoc.conf.json",
    "docs:serve": "jsdoc -c jsdoc.conf.json && serve docs/",
    
    "docker:build": "docker build -t vps-pk-cloud .",
    "docker:run": "docker run -d -p 3000:3000 --name vps-pk-cloud vps-pk-cloud",
    "docker:stop": "docker stop vps-pk-cloud && docker rm vps-pk-cloud",
    
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop vps-pk-cloud",
    "pm2:restart": "pm2 restart vps-pk-cloud",
    "pm2:logs": "pm2 logs vps-pk-cloud",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [
    "cloud",
    "computing",
    "infrastructure",
    "platform",
    "api",
    "services",
    "aws",
    "azure",
    "gcp",
    "oracle",
    "compute",
    "storage",
    "database",
    "networking",
    "ai",
    "ml",
    "security",
    "compliance"
  ],
  "author": "VPS-PK Cloud",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0",
    "uuid": "^9.0.0",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "crypto": "^1.0.1",
    "fs-extra": "^11.1.1",
    "path": "^0.12.7",
    "os": "^0.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "eslint": "^8.45.0",
    "jsdoc": "^4.0.2",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vps-pk/vps-pk-cloud-platform.git"
  },
  "bugs": {
    "url": "https://github.com/vps-pk/vps-pk-cloud-platform/issues"
  },
  "homepage": "https://www.vps-pk.com",
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "indent": ["error", 2],
      "linebreak-style": ["error", "unix"],
      "quotes": ["error", "single"],
      "semi": ["error", "always"],
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  }
}
